{
  "fps": 30,
  "total_duration_seconds": 60.0,
  "total_frames": 1800,
  "segments": [
    {
      "id": 1,
      "section": "hook",
      "from_time": 0.1,
      "to_time": 5.667,
      "from_frame": 3,
      "to_frame": 170,
      "text": "優秀な人が黙って去る会社の特徴、3選です。"
    },
    {
      "id": 2,
      "section": "hook",
      "from_time": 5.667,
      "to_time": 5.7,
      "from_frame": 170,
      "to_frame": 171,
      "text": "一つでも当てはまっていたら、その職場は危険かもしれません。"
    },
    {
      "id": 3,
      "section": "s1",
      "from_time": 5.9,
      "to_time": 21.5,
      "from_frame": 177,
      "to_frame": 645,
      "text": "現場の意見が完全スルーされる。"
    },
    {
      "id": 4,
      "section": "s1",
      "from_time": 21.5,
      "to_time": 21.533,
      "from_frame": 645,
      "to_frame": 646,
      "text": "優秀な人は常に「より良くしたい」と改善案を出します。"
    },
    {
      "id": 5,
      "section": "s1",
      "from_time": 21.533,
      "to_time": 21.567,
      "from_frame": 646,
      "to_frame": 647,
      "text": "でも、それを「前例がない」「検討する」と流し続ける会社。"
    },
    {
      "id": 6,
      "section": "s1",
      "from_time": 21.567,
      "to_time": 21.6,
      "from_frame": 647,
      "to_frame": 648,
      "text": "本来、意見を求めるなら実行する責任が伴うはずです。"
    },
    {
      "id": 7,
      "section": "s1",
      "from_time": 21.6,
      "to_time": 21.633,
      "from_frame": 648,
      "to_frame": 649,
      "text": "「言っても無駄だ」と悟ったとき、優秀な人は静かに席を立ちます。"
    },
    {
      "id": 8,
      "section": "s2",
      "from_time": 21.7,
      "to_time": 36.167,
      "from_frame": 651,
      "to_frame": 1085,
      "text": "頑張った分だけ損をする評価。"
    },
    {
      "id": 9,
      "section": "s2",
      "from_time": 36.167,
      "to_time": 36.2,
      "from_frame": 1085,
      "to_frame": 1086,
      "text": "優秀な人にばかり仕事が集中し、評価は横並び。"
    },
    {
      "id": 10,
      "section": "s2",
      "from_time": 36.2,
      "to_time": 36.233,
      "from_frame": 1086,
      "to_frame": 1087,
      "text": "「君ならできる」という言葉が、ただの押し付けになっている環境。"
    },
    {
      "id": 11,
      "section": "s2",
      "from_time": 36.233,
      "to_time": 36.267,
      "from_frame": 1087,
      "to_frame": 1088,
      "text": "これでは頑張るほど疲弊し、モチベーションが削られるだけです。"
    },
    {
      "id": 12,
      "section": "s2",
      "from_time": 36.267,
      "to_time": 36.3,
      "from_frame": 1088,
      "to_frame": 1089,
      "text": "会社が不公平に甘えていると、実力のある人から抜けていきます。"
    },
    {
      "id": 13,
      "section": "s3",
      "from_time": 36.333,
      "to_time": 50.6,
      "from_frame": 1090,
      "to_frame": 1518,
      "text": "尊敬できる上司が一人もいない。"
    },
    {
      "id": 14,
      "section": "s3",
      "from_time": 50.6,
      "to_time": 50.633,
      "from_frame": 1518,
      "to_frame": 1519,
      "text": "「この人のようになりたい」と思えるロールモデルがいない。"
    },
    {
      "id": 15,
      "section": "s3",
      "from_time": 50.633,
      "to_time": 50.667,
      "from_frame": 1519,
      "to_frame": 1520,
      "text": "上にいるのが、保身ばかりの人間や、指示待ちの人間。"
    },
    {
      "id": 16,
      "section": "s3",
      "from_time": 50.667,
      "to_time": 50.7,
      "from_frame": 1520,
      "to_frame": 1521,
      "text": "優秀な人は、自分の「未来の姿」を見て転職を決意します。"
    },
    {
      "id": 17,
      "section": "s3",
      "from_time": 50.7,
      "to_time": 50.733,
      "from_frame": 1521,
      "to_frame": 1522,
      "text": "尊敬が消えた瞬間、そこはもう居場所ではなくなるのです。"
    },
    {
      "id": 18,
      "section": "cta",
      "from_time": 50.833,
      "to_time": 57.733,
      "from_frame": 1525,
      "to_frame": 1732,
      "text": "こういう会社は仕組みが変わらない限り、状況は変わりません。"
    },
    {
      "id": 19,
      "section": "cta",
      "from_time": 57.733,
      "to_time": 57.767,
      "from_frame": 1732,
      "to_frame": 1733,
      "text": "ぜひ保存して、自分の環境を見直し、より良い未来を目指してください。"
    }
  ],
