{
  "fps": 30,
  "total_duration_seconds": 60.0,
  "total_frames": 1800,
  "segments": [
    {
      "id": 1,
      "section": "hook",
      "from_time": 0.1,
      "to_time": 5.5,
      "from_frame": 3,
      "to_frame": 165,
      "text": "優秀な人が黙って去る会社の特徴、3選です。"
    },
    {
      "id": 2,
      "section": "hook",
      "from_time": 5.5,
      "to_time": 5.533,
      "from_frame": 165,
      "to_frame": 166,
      "text": "一つでも当てはまっていたら、その職場は危険かもしれません。"
    },
    {
      "id": 3,
      "section": "s1",
      "from_time": 5.767,
      "to_time": 20.533,
      "from_frame": 173,
      "to_frame": 616,
      "text": "現場の意見が完全スルーされる。"
    },
    {
      "id": 4,
      "section": "s1",
      "from_time": 20.533,
      "to_time": 20.567,
      "from_frame": 616,
      "to_frame": 617,
      "text": "優秀な人は常に「より良くしたい」と改善案を出します。"
    },
    {
      "id": 5,
      "section": "s1",
      "from_time": 20.567,
      "to_time": 20.6,
      "from_frame": 617,
      "to_frame": 618,
      "text": "でも、それを「前例がない」「検討する」と流し続ける会社。"
    },
    {
      "id": 6,
      "section": "s1",
      "from_time": 20.6,
      "to_time": 20.633,
      "from_frame": 618,
      "to_frame": 619,
      "text": "本来、意見を求めるなら実行する責任が伴うはずです。"
    },
    {
      "id": 7,
      "section": "s1",
      "from_time": 20.633,
      "to_time": 20.667,
      "from_frame": 619,
      "to_frame": 620,
      "text": "「言っても無駄だ」と悟ったとき、優秀な人は静かに席を立ちます。"
    },
    {
      "id": 8,
      "section": "s2",
      "from_time": 20.833,
      "to_time": 34.467,
      "from_frame": 625,
      "to_frame": 1034,
      "text": "頑張った分だけ損をする評価。"
    },
    {
      "id": 9,
      "section": "s2",
      "from_time": 34.467,
      "to_time": 34.5,
      "from_frame": 1034,
      "to_frame": 1035,
      "text": "優秀な人にばかり仕事が集中し、評価は横並び。"
    },
    {
      "id": 10,
      "section": "s2",
      "from_time": 34.5,
      "to_time": 34.533,
      "from_frame": 1035,
      "to_frame": 1036,
      "text": "「君ならできる」という言葉が、ただの押し付けになっている環境。"
    },
    {
      "id": 11,
      "section": "s2",
      "from_time": 34.533,
      "to_time": 34.567,
      "from_frame": 1036,
      "to_frame": 1037,
      "text": "これでは頑張るほど疲弊し、モチベーションが削られるだけです。"
    },
    {
      "id": 12,
      "section": "s2",
      "from_time": 34.567,
      "to_time": 34.6,
      "from_frame": 1037,
      "to_frame": 1038,
      "text": "会社が不公平に甘えていると、実力のある人から抜けていきます。"
    },
    {
      "id": 13,
      "section": "s3",
      "from_time": 34.767,
      "to_time": 48.167,
      "from_frame": 1043,
      "to_frame": 1445,
      "text": "尊敬できる上司が一人もいない。"
    },
    {
      "id": 14,
      "section": "s3",
      "from_time": 48.167,
      "to_time": 48.2,
      "from_frame": 1445,
      "to_frame": 1446,
      "text": "「この人のようになりたい」と思えるロールモデルがいない。"
    },
    {
      "id": 15,
      "section": "s3",
      "from_time": 48.2,
      "to_time": 48.233,
      "from_frame": 1446,
      "to_frame": 1447,
      "text": "上にいるのが、保身ばかりの人間や、指示待ちの人間。"
    },
    {
      "id": 16,
      "section": "s3",
      "from_time": 48.233,
      "to_time": 48.267,
      "from_frame": 1447,
      "to_frame": 1448,
      "text": "優秀な人は、自分の「未来の姿」を見て転職を決意します。"
    },
    {
      "id": 17,
      "section": "s3",
      "from_time": 48.267,
      "to_time": 48.3,
      "from_frame": 1448,
      "to_frame": 1449,
      "text": "尊敬が消えた瞬間、そこはもう居場所ではなくなるのです。"
    },
    {
      "id": 18,
      "section": "cta",
      "from_time": 48.467,
      "to_time": 54.967,
      "from_frame": 1454,
      "to_frame": 1649,
      "text": "こういう会社は仕組みが変わらない限り、状況は変わりません。"
    },
    {
      "id": 19,
      "section": "cta",
      "from_time": 54.967,
      "to_time": 55.0,
      "from_frame": 1649,
      "to_frame": 1650,
      "text": "ぜひ保存して、自分の環境を見直し、より良い未来を目指してください。"
    }
  ],
