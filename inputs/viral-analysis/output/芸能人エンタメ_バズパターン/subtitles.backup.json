      "from_time": 5.467,
      "to_time": 7.367,
      "from_frame": 164,
      "to_frame": 221,
      "text": "最後の一人は、\nそのイメージを"
    },
    {
      "id": 4,
      "section": "opening",
      "from_time": 7.367,
      "to_time": 9.2,
      "from_frame": 221,
      "to_frame": 276,
      "text": "全部ひっくり返した。"
    },
    {
      "id": 5,
      "section": "s1",
      "from_time": 9.567,
      "to_time": 11.767,
      "from_frame": 287,
      "to_frame": 353,
      "text": "1人目は、\n吉高由里子。"
    },
    {
      "id": 6,
      "section": "s1",
      "from_time": 11.767,
      "to_time": 14.6,
      "from_frame": 353,
      "to_frame": 438,
      "text": "デビュー作\n『蛇にピアス』で"
    },
    {
      "id": 7,
      "section": "s1",
      "from_time": 14.6,
      "to_time": 17.3,
      "from_frame": 438,
      "to_frame": 519,
      "text": "体当たり演技が衝撃。"
    },
    {
      "id": 8,
      "section": "s1",
      "from_time": 17.3,
      "to_time": 21.233,
      "from_frame": 519,
      "to_frame": 637,
      "text": "ピアスにタトゥー、\n過激な役柄を\n演じ切り、"
    },
    {
      "id": 9,
      "section": "s1",
      "from_time": 21.233,
      "to_time": 25.133,
      "from_frame": 637,
      "to_frame": 754,
      "text": "清楚なイメージ\nとのギャップが\n一気に話題に\nなった。"
    },
    {
      "id": 10,
      "section": "s2",
      "from_time": 25.567,
      "to_time": 27.433,
      "from_frame": 767,
      "to_frame": 823,
      "text": "2人目は、\n長澤まさみ。"
    },
    {
      "id": 11,
      "section": "s2",
      "from_time": 27.433,
      "to_time": 29.8,
      "from_frame": 823,
      "to_frame": 894,
      "text": "清純派出身なのに、"
    },
    {
      "id": 12,
      "section": "s2",
      "from_time": 29.8,
      "to_time": 32.6,
      "from_frame": 894,
      "to_frame": 978,
      "text": "難しい役へ次々挑戦。"
    },
    {
      "id": 13,
      "section": "s2",
      "from_time": 32.6,
      "to_time": 35.9,
      "from_frame": 978,
      "to_frame": 1077,
      "text": "大胆な役柄も\n引き受けて、"
    },
    {
      "id": 14,
      "section": "s2",
      "from_time": 35.9,
      "to_time": 38.7,
      "from_frame": 1077,
      "to_frame": 1161,
      "text": "女優としての\n振り幅の広さを\n見せつけた。"
    },
    {
      "id": 15,
      "section": "s3",
      "from_time": 39.1,
      "to_time": 41.267,
      "from_frame": 1173,
      "to_frame": 1238,
      "text": "3人目は、\n深田恭子。"
    },
    {
      "id": 16,
      "section": "s3",
      "from_time": 41.267,
      "to_time": 43.833,
      "from_frame": 1238,
      "to_frame": 1315,
      "text": "デビュー当初から\n色気のある役でも"
    },
    {
      "id": 17,
      "section": "s3",
      "from_time": 43.833,
      "to_time": 46.4,
      "from_frame": 1315,
      "to_frame": 1392,
      "text": "存在感が別格。"
    },
    {
      "id": 18,
      "section": "s3",
      "from_time": 46.4,
      "to_time": 48.6,
      "from_frame": 1392,
      "to_frame": 1458,
      "text": "今も語られる\nあのギャップに、"
    },
    {
      "id": 19,
      "section": "s3",
      "from_time": 48.6,
      "to_time": 50.3,
      "from_frame": 1458,
      "to_frame": 1509,
      "text": "根強いファンが\n離れない。"
    },
    {
      "id": 20,
      "section": "cta",
      "from_time": 50.733,
      "to_time": 52.233,
      "from_frame": 1522,
      "to_frame": 1567,
      "text": "知らなかった人は、"
    },
    {
      "id": 21,
      "section": "cta",
      "from_time": 52.233,
      "to_time": 53.733,
      "from_frame": 1567,
      "to_frame": 1612,
      "text": "フォローして\n次も見て！"
    }
