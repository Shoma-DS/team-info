      "to_time": 5.2,
      "from_frame": 126,
      "to_frame": 156,
      "text": "所属事務所から\n過密"
    },
    {
      "id": 4,
      "section": "s1",
      "from_time": 5.2,
      "to_time": 6.633,
      "from_frame": 156,
      "to_frame": 199,
      "text": "スケジュールを\n強いられ続け"
    },
    {
      "id": 5,
      "section": "s1",
      "from_time": 6.633,
      "to_time": 7.867,
      "from_frame": 199,
      "to_frame": 236,
      "text": "年間100本\n超えの仕事を"
    },
    {
      "id": 6,
      "section": "s1",
      "from_time": 7.867,
      "to_time": 8.967,
      "from_frame": 236,
      "to_frame": 269,
      "text": "本人の意志とは\n無関係に"
    },
    {
      "id": 7,
      "section": "s1",
      "from_time": 8.967,
      "to_time": 10.633,
      "from_frame": 269,
      "to_frame": 319,
      "text": "限界を超えた\n彼女は突如"
    },
    {
      "id": 8,
      "section": "s1",
      "from_time": 10.633,
      "to_time": 11.367,
      "from_frame": 319,
      "to_frame": 341,
      "text": "引退を宣言"
    },
    {
      "id": 9,
      "section": "s1",
      "from_time": 11.367,
      "to_time": 14.733,
      "from_frame": 341,
      "to_frame": 442,
      "text": "事務所との\n確執が世間を"
    },
    {
      "id": 10,
      "section": "s1",
      "from_time": 14.733,
      "to_time": 16.233,
      "from_frame": 442,
      "to_frame": 487,
      "text": "震撼させた"
    },
    {
      "id": 11,
      "section": "s2",
      "from_time": 16.467,
      "to_time": 18.8,
      "from_frame": 494,
      "to_frame": 564,
      "text": "2.能年玲奈"
    },
    {
      "id": 12,
      "section": "s2",
      "from_time": 18.8,
      "to_time": 20.867,
      "from_frame": 564,
      "to_frame": 626,
      "text": "NHK朝ドラで\n国民的人気を"
    },
    {
      "id": 13,
      "section": "s2",
      "from_time": 20.867,
      "to_time": 21.5,
      "from_frame": 626,
      "to_frame": 645,
      "text": "得た直後"
    },
    {
      "id": 14,
      "section": "s2",
      "from_time": 21.5,
      "to_time": 23.4,
      "from_frame": 645,
      "to_frame": 702,
      "text": "事務所の意向で\n活動を徹底的に"
    },
    {
      "id": 15,
      "section": "s2",
      "from_time": 23.4,
      "to_time": 24.033,
      "from_frame": 702,
      "to_frame": 721,
      "text": "制限された"
    },
    {
      "id": 16,
      "section": "s2",
      "from_time": 24.033,
      "to_time": 25.267,
      "from_frame": 721,
      "to_frame": 758,
      "text": "本名すら\n使えなくなり"
    },
    {
      "id": 17,
      "section": "s2",
      "from_time": 25.267,
      "to_time": 26.467,
      "from_frame": 758,
      "to_frame": 794,
      "text": "「のん」として\n再出発"
    },
    {
      "id": 18,
      "section": "s2",
      "from_time": 26.467,
      "to_time": 28.067,
      "from_frame": 794,
      "to_frame": 842,
      "text": "業界の闇を\n全国に"
    },
