      "id": 19,
      "section": "s2",
      "from_time": 28.067,
      "to_time": 30.433,
      "from_frame": 842,
      "to_frame": 913,
      "text": "知らしめた\n一件として今も"
    },
    {
      "id": 20,
      "section": "s2",
      "from_time": 30.433,
      "to_time": 32.033,
      "from_frame": 913,
      "to_frame": 961,
      "text": "語り継がれて\nいる"
    },
    {
      "id": 21,
      "section": "s3",
      "from_time": 32.3,
      "to_time": 34.067,
      "from_frame": 969,
      "to_frame": 1022,
      "text": "3.飯島直子"
    },
