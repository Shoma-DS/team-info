      "from_time": 34.067,
      "to_time": 35.033,
      "from_frame": 1022,
      "to_frame": 1051,
      "text": "デビュー当初\nから過激な"
    },
    {
      "id": 23,
      "section": "s3",
      "from_time": 35.033,
      "to_time": 36.067,
      "from_frame": 1051,
      "to_frame": 1082,
      "text": "グラビアを\n量産させられた"
    },
    {
      "id": 24,
      "section": "s3",
      "from_time": 36.067,
      "to_time": 37.5,
      "from_frame": 1082,
      "to_frame": 1125,
      "text": "「やりたく\nなかった」と"
    },
    {
      "id": 25,
      "section": "s3",
      "from_time": 37.5,
      "to_time": 38.033,
      "from_frame": 1125,
      "to_frame": 1141,
      "text": "後年告白"
    },
    {
      "id": 26,
      "section": "s3",
      "from_time": 38.033,
      "to_time": 40.3,
      "from_frame": 1141,
      "to_frame": 1209,
      "text": "それでも\n生き残るために"
    },
    {
      "id": 27,
      "section": "s3",
      "from_time": 40.3,
      "to_time": 41.967,
      "from_frame": 1209,
      "to_frame": 1259,
      "text": "従うしか\nなかった"
    },
    {
      "id": 28,
