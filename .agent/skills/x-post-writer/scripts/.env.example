# このファイルは x_metrics_collector.py で使う環境変数の見本です。
# 実際の値は書かず、各自のローカル環境で設定してください。

# ============================================
# X API 認証情報（全アカウント共通）
# X Developer Portal > アプリ > Keys and Tokens で取得
# ============================================
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=

# ============================================
# Neon PostgreSQL 接続文字列
# Neon コンソール > プロジェクト > 接続文字列で取得
# ============================================
NEON_DATABASE_URL=

# ============================================
# X アカウント別アクセストークン
# アカウントごとに追加する。変数名末尾の識別子は accounts_config.json の id に合わせる
# 例: id="GUTARA" → X_ACCESS_TOKEN_GUTARA / X_ACCESS_TOKEN_SECRET_GUTARA
# ============================================
X_ACCESS_TOKEN_GUTARA=
X_ACCESS_TOKEN_SECRET_GUTARA=
