# このファイルは x_metrics_collector.py で使う環境変数の見本です。
# 実際の値は書かず、各自のローカル環境で設定してください。

# ============================================
# X API 認証情報（全アカウント共通）
# X Developer Portal > アプリ > Keys and Tokens で取得
# ============================================
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=

# ============================================
# Neon PostgreSQL 接続文字列
# Neon コンソール > プロジェクト > 接続文字列で取得
# ============================================
NEON_DATABASE_URL=

# ============================================
# X アカウント別アクセストークン
# アカウントごとに追加する。変数名末尾の識別子は X アカウント名を大文字化して使う
# 例: x_username="gutaraAikatuyou" → GUTARAAIKATUYOU
# ============================================
X_ACCESS_TOKEN_GUTARAAIKATUYOU=
X_ACCESS_TOKEN_SECRET_GUTARAAIKATUYOU=
X_BOOKMARKS_ACCESS_TOKEN_GUTARAAIKATUYOU=
X_BOOKMARKS_REFRESH_TOKEN_GUTARAAIKATUYOU=
X_OAUTH2_CLIENT_ID_GUTARAAIKATUYOU=
X_OAUTH2_CLIENT_SECRET_GUTARAAIKATUYOU=
