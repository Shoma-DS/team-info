      "from_time": 4.2,
      "to_time": 5.345,
      "from_frame": 126,
      "to_frame": 160,
      "text": "所属事務所から\n過密"
    },
    {
      "id": 4,
      "section": "s1",
      "from_time": 5.345,
      "to_time": 7.0,
      "from_frame": 160,
      "to_frame": 210,
      "text": "スケジュールを\n強いられ続け"
    },
    {
      "id": 5,
      "section": "s1",
      "from_time": 7.0,
      "to_time": 8.409,
      "from_frame": 210,
      "to_frame": 252,
      "text": "年間100本\n超えの仕事を"
    },
    {
      "id": 6,
      "section": "s1",
      "from_time": 8.409,
      "to_time": 9.7,
      "from_frame": 252,
      "to_frame": 291,
      "text": "本人の意志とは\n無関係に"
    },
    {
      "id": 7,
      "section": "s1",
      "from_time": 9.7,
      "to_time": 11.625,
      "from_frame": 291,
      "to_frame": 349,
      "text": "限界を超えた\n彼女は突如"
    },
    {
      "id": 8,
      "section": "s1",
      "from_time": 11.625,
      "to_time": 12.5,
      "from_frame": 349,
      "to_frame": 375,
      "text": "引退を宣言"
    },
    {
      "id": 9,
      "section": "s1",
      "from_time": 12.5,
      "to_time": 16.35,
      "from_frame": 375,
      "to_frame": 491,
      "text": "事務所との\n確執が世間を"
    },
    {
      "id": 10,
      "section": "s1",
      "from_time": 16.35,
      "to_time": 18.1,
      "from_frame": 491,
      "to_frame": 543,
      "text": "震撼させた"
    },
    {
      "id": 11,
      "section": "s2",
      "from_time": 18.2,
      "to_time": 20.7,
      "from_frame": 546,
      "to_frame": 621,
      "text": "2.能年玲奈"
    },
    {
      "id": 12,
      "section": "s2",
      "from_time": 20.7,
      "to_time": 22.892,
      "from_frame": 621,
      "to_frame": 687,
      "text": "NHK朝ドラで\n国民的人気を"
    },
    {
      "id": 13,
      "section": "s2",
      "from_time": 22.892,
      "to_time": 23.567,
      "from_frame": 687,
      "to_frame": 707,
      "text": "得た直後"
    },
    {
      "id": 14,
      "section": "s2",
      "from_time": 23.567,
      "to_time": 25.581,
      "from_frame": 707,
      "to_frame": 767,
      "text": "事務所の意向で\n活動を徹底的に"
    },
    {
      "id": 15,
      "section": "s2",
      "from_time": 25.581,
      "to_time": 26.3,
      "from_frame": 767,
      "to_frame": 789,
      "text": "制限された"
    },
    {
      "id": 16,
      "section": "s2",
      "from_time": 26.3,
      "to_time": 27.6,
      "from_frame": 789,
      "to_frame": 828,
      "text": "本名すら\n使えなくなり"
    },
    {
      "id": 17,
      "section": "s2",
      "from_time": 27.6,
      "to_time": 28.9,
      "from_frame": 828,
      "to_frame": 867,
      "text": "「のん」として\n再出発"
    },
    {
      "id": 18,
      "section": "s2",
      "from_time": 28.9,
      "to_time": 30.595,
      "from_frame": 867,
      "to_frame": 918,
      "text": "業界の闇を\n全国に"
    },
    {
      "id": 19,
      "section": "s2",
      "from_time": 30.595,
      "to_time": 33.138,
      "from_frame": 918,
      "to_frame": 994,
      "text": "知らしめた\n一件として今も"
    },
    {
      "id": 20,
      "section": "s2",
      "from_time": 33.138,
      "to_time": 34.833,
      "from_frame": 994,
      "to_frame": 1045,
      "text": "語り継がれて\nいる"
    },
    {
      "id": 21,
      "section": "s3",
      "from_time": 34.967,
      "to_time": 36.733,
      "from_frame": 1049,
      "to_frame": 1102,
      "text": "3.飯島直子"
    },
    {
      "id": 22,
      "section": "s3",
      "from_time": 36.733,
      "to_time": 37.69,
      "from_frame": 1102,
      "to_frame": 1131,
      "text": "デビュー当初\nから過激な"
    },
    {
      "id": 23,
      "section": "s3",
      "from_time": 37.69,
      "to_time": 38.733,
      "from_frame": 1131,
      "to_frame": 1162,
      "text": "グラビアを\n量産させられた"
    },
    {
      "id": 24,
      "section": "s3",
      "from_time": 38.733,
      "to_time": 40.151,
      "from_frame": 1162,
      "to_frame": 1205,
      "text": "「やりたく\nなかった」と"
    },
    {
      "id": 25,
      "section": "s3",
      "from_time": 40.151,
      "to_time": 40.667,
      "from_frame": 1205,
      "to_frame": 1220,
      "text": "後年告白"
    },
    {
      "id": 26,
      "section": "s3",
      "from_time": 40.667,
      "to_time": 42.944,
      "from_frame": 1220,
      "to_frame": 1288,
      "text": "それでも\n生き残るために"
    },
    {
      "id": 27,
      "section": "s3",
      "from_time": 42.944,
      "to_time": 44.6,
      "from_frame": 1288,
      "to_frame": 1338,
      "text": "従うしかなかっ\nた"
    },
    {
      "id": 28,
      "section": "s3",
      "from_time": 44.6,
      "to_time": 48.367,
      "from_frame": 1338,
      "to_frame": 1451,
      "text": "芸能界の現実が\nそこにあった"
    },
    {
      "id": 29,
      "section": "cta",
      "from_time": 48.467,
      "to_time": 50.456,
      "from_frame": 1454,
      "to_frame": 1514,
      "text": "以上、事務所に\n売られた芸能人"
    },
    {
      "id": 30,
